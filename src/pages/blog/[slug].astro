---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Calendar, User, Tag, ArrowLeft } from "lucide-react";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(date);
}
---

<BaseLayout
  title={`${post.data.title} | Kauai Hot Yoga`}
  description={post.data.description}
  ogImage={post.data.image}
  currentPath={`/blog/${post.slug}`}
>
  <div class="min-h-screen bg-white">
    {/* Cover image */}
    {post.data.image && (
      <div class="w-full h-72 md:h-96 overflow-hidden">
        <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
      </div>
    )}

    <div class="container mx-auto px-4 py-16">
      <div class="max-w-2xl mx-auto">

        {/* Back link */}
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-purple/70 hover:text-purple transition-colors mb-8">
          <ArrowLeft size={16} />
          Back to Blog
        </a>

        {/* Tags */}
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs font-semibold text-orange uppercase tracking-widest">{tag}</span>
            ))}
          </div>
        )}

        {/* Title */}
        <h1 class="text-4xl md:text-5xl font-bold text-purple-dark mb-6 leading-tight">
          {post.data.title}
        </h1>

        {/* Meta */}
        <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground mb-12 pb-8 border-b border-soft-purple">
          <span class="flex items-center gap-1.5">
            <Calendar size={14} />
            {formatDate(post.data.pubDate)}
          </span>
          <span class="flex items-center gap-1.5">
            <User size={14} />
            {post.data.author}
          </span>
        </div>

        {/* Markdown content */}
        <article class="prose prose-purple max-w-none
          prose-headings:text-purple-dark prose-headings:font-bold
          prose-p:text-purple-dark/80 prose-p:leading-relaxed
          prose-a:text-purple prose-a:no-underline hover:prose-a:underline
          prose-strong:text-purple-dark
          prose-ul:text-purple-dark/80 prose-li:my-1
          prose-hr:border-soft-purple
        ">
          <Content />
        </article>

        {/* CTA */}
        <div class="mt-16 p-8 bg-soft-purple/30 rounded-2xl text-center">
          <p class="text-purple-dark font-semibold mb-2">Ready to experience it for yourself?</p>
          <p class="text-muted-foreground text-sm mb-5">New clients: 3 classes for $59.</p>
          <a
            href="/pricing"
            class="inline-block bg-orange text-white font-semibold px-8 py-3 rounded-full hover:bg-orange-dark transition-colors"
          >
            View Pricing
          </a>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>
