---
import { getCollection, getEntry } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { HomePage } from "../app/pages/home";
import heroMainImg from "../assets/images/hero-main.jpg";

const heroMobile = await getImage({ src: heroMainImg, width: 768, format: "webp", quality: 80 });

const homeEntry = await getEntry("home", "main");
if (!homeEntry) throw new Error("Missing content: home/main.yml");

const settingsEntry = await getEntry("settings", "main");
if (!settingsEntry) throw new Error("Missing content: settings/main.yml");

const testimonialEntries = await getCollection("testimonials");
const testimonials = testimonialEntries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((e) => e.data);

const offeringEntries = await getCollection("offerings");
const offerings = offeringEntries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((e) => e.data);

const teacherEntries = await getCollection("teachers");
const teachers = teacherEntries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((e) => ({ name: e.data.name, title: e.data.title, photo: e.data.photo }));
---

<BaseLayout
  title="Hot Yoga Studio in Kauai, Hawaii | Kauai Hot Yoga"
  description="Kauai Hot Yoga is Kauai's premier hot yoga studio in Lihue, Hawaii. Hot yoga classes, 9D breathwork, cold plunge, and wellness workshops. All levels welcome."
  currentPath="/">
  <HomePage
    content={homeEntry.data}
    testimonials={testimonials}
    offerings={offerings}
    teachers={teachers}
    googleReviewUrl={settingsEntry.data.social?.google_review_url ?? ""}
    yelpReviewUrl={settingsEntry.data.social?.yelp_review_url ?? ""}
    phone={settingsEntry.data.phone ?? ""}
    heroMobileSrc={heroMobile.src}
    client:load
  />
</BaseLayout>