---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ContactPage } from "../app/pages/contact";

const settingsEntry = await getEntry("settings", "main");
if (!settingsEntry) throw new Error("Missing content: settings/main.yml");
---

<BaseLayout title="Contact | Kauai Hot Yoga" description="Get in touch with Kauai Hot Yoga. Find our address, phone number, email, and studio hours." currentPath="/contact-us">
  <ContactPage info={settingsEntry.data} client:load />
</BaseLayout>
