---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ClassesPage } from "../app/pages/classes";
import studioInteriorImg from "../assets/images/studio-interior.jpg";

const classEntries = await getCollection("classes");
const classes = classEntries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((e) => e.data);

const heroDesktop = await getImage({ src: studioInteriorImg, width: 1600, format: "webp", quality: 85 });
const heroMobile  = await getImage({ src: studioInteriorImg, width: 768,  format: "webp", quality: 80 });
---

<BaseLayout
  title="Hot Yoga Classes in Kauai, Hawaii | Kauai Hot Yoga"
  description="Explore our hot yoga class styles — Hot 26 & 2, Power Flow, Yin & Restore, and more — at our Lihue, Kauai studio. All levels welcome."
  ogImage="/images/classes-hero.jpg"
  currentPath="/classes">
  <ClassesPage classes={classes} heroDesktopSrc={heroDesktop.src} heroMobileSrc={heroMobile.src} client:visible />
</BaseLayout>