---
import { getEntry } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { AboutPage } from "../views/about";
import aboutStudioImg from "../assets/images/about-studio.webp";

const aboutEntry = await getEntry("about", "main");
if (!aboutEntry) throw new Error("Missing content: about/main.yml");

const heroDesktop    = await getImage({ src: aboutStudioImg, width: 1600, format: "webp", quality: 85 });
const heroMobile     = await getImage({ src: aboutStudioImg, width: 768,  format: "webp", quality: 80 });
const studioDesktopSrc = aboutEntry.data.studio_image_desktop;
const studioMobileSrc = aboutEntry.data.studio_image_mobile;
---

<BaseLayout
  title={aboutEntry.data.seo_title}
  description={aboutEntry.data.seo_description}
  currentPath="/our-studio">
  <AboutPage
    content={aboutEntry.data}
    heroDesktopSrc={heroDesktop.src}
    heroMobileSrc={heroMobile.src}
    studioDesktopSrc={studioDesktopSrc}
    studioMobileSrc={studioMobileSrc}
    client:visible
  />
</BaseLayout>
