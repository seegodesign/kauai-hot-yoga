---
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SchedulePage } from "../app/pages/schedule";
import scheduleHeroImg from "../assets/images/schedule-hero.jpg";

const heroDesktop = await getImage({ src: scheduleHeroImg, width: 1600, format: "webp", quality: 85 });
const heroMobile  = await getImage({ src: scheduleHeroImg, width: 768,  format: "webp", quality: 80 });
---

<BaseLayout
  title="Class Schedule | Kauai Hot Yoga"
  description="View the weekly hot yoga class schedule and book your spot at Kauai Hot Yoga."
  ogImage="/images/schedule-hero.jpg"
  currentPath="/schedule">
  <SchedulePage heroDesktopSrc={heroDesktop.src} heroMobileSrc={heroMobile.src} client:visible />
</BaseLayout>