---
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import scheduleHeroImg from "../assets/images/schedule-hero.webp";

const heroDesktop = await getImage({ src: scheduleHeroImg, width: 1920, format: "webp", quality: 80 });
const heroMobile  = await getImage({ src: scheduleHeroImg, width: 768,  format: "webp", quality: 80 });
---

<BaseLayout
  title="Class Schedule | Kauai Hot Yoga"
  description="View the weekly hot yoga class schedule and book your spot at Kauai Hot Yoga."
  ogImage="/images/schedule-hero.webp"
  currentPath="/schedule">

  {/* Hero */}
  <section class="relative min-h-[60svh] flex items-center justify-center overflow-hidden">
    <picture>
      <source media="(max-width: 767px)" srcset={heroMobile.src} />
      <img
        src={heroDesktop.src}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      />
    </picture>
    <div class="absolute inset-0 bg-purple-dark/65"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-orange/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative container mx-auto px-4 text-center">
      <span class="inline-block text-orange-light font-semibold tracking-widest uppercase text-sm mb-4">
        Plan Your Week
      </span>
      <h1 class="text-5xl md:text-6xl lg:text-7xl text-white font-bold mb-4">Class Schedule</h1>
      <p class="text-white/85 text-lg md:text-xl max-w-2xl mx-auto">
        Browse upcoming classes and book your spot directly through Mindbody.
      </p>
    </div>
  </section>

  <div class="py-10 px-4 bg-white">
    <div class="container mx-auto max-w-5xl">
      <!-- Mindbody Schedules widget begin -->
      <div class="mindbody-widget" data-widget-type="Schedules" data-widget-id="3f50039f769"></div>
      <script async src="https://brandedweb.mindbodyonline.com/embed/widget.js"></script>
      <!-- Mindbody Schedules widget end -->
    </div>
  </div>
</BaseLayout>
